# Скопируйте этот файл в infra/.env и заполните значения.
# docker compose автоматически подхватывает infra/.env для подстановки ${...}.

# --- SMTP (Mail.ru) ---
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
# Логин — полный адрес ящика Mail.ru
SMTP_USERNAME=your_account@mail.ru
# Пароль для внешнего приложения (НЕ обычный пароль от почты!):
# Mail.ru → Настройки → Безопасность → Пароли для внешних приложений
SMTP_PASSWORD=your_app_password
# Отправитель (обычно тот же адрес, что и SMTP_USERNAME)
SMTP_FROM_EMAIL=your_account@mail.ru

# URL фронтенда для ссылки сброса пароля
FRONTEND_URL=http://localhost:3000
